{
  "name": "@polyforge/mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Polyforge — lets AI assistants trade prediction markets via the Model Context Protocol",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "polyforge-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "polyforge",
    "polymarket",
    "prediction-markets",
    "trading",
    "ai",
    "claude",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/polyforge-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.12",
      "@hono/node-server": ">=1.19.13"
    }
  }
}
